# ==============================================================================
# BhoomiOne V2 - Pre-Configured VPS Staging Environment Configuration Template
# Copy this file to .env.staging or .env on the server.
# ==============================================================================

# Core Application Configuration
APP_NAME="BhoomiOne V2 ERP"
APP_ENV=staging
APP_DEBUG=false
APP_URL=http://127.0.0.1:8097

# APP_KEY: Run "php artisan key:generate" in backend-api container to generate this value
APP_KEY=SomeRandomKeyPlaceholderToGenerateOnServer

LOG_CHANNEL=stack
LOG_LEVEL=error

# Backend PostgreSQL Database Configuration
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=bhoomione_v2_staging
DB_USERNAME=bhoomione_v2
DB_PASSWORD=ChangeThisStrongDbPassword2026

# Session & Cache Settings
BROADCAST_DRIVER=log
CACHE_DRIVER=redis
FILESYSTEM_DISK=public
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# Redis Cache Service Credentials
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=ChangeThisStrongRedisPassword2026

# Storage Public Link Configuration
ASSET_URL=http://127.0.0.1:8097/storage

# Spatial & CAD Ingestion Settings
MAX_DXF_PARSE_BODY_SIZE_MB=100
QUEUE_WORKER_TIMEOUT_SECONDS=180
AUTO_COMPILE_VECTORS_ON_IMPORT=true

# React Frontend Routing Override
VITE_LARAVEL_API_URL=/api/v1

# Seeding Controls
SEED_DEMO_DATA=false

# QA Simulation and Auditing Control
VITE_ENABLE_QA_SIMULATION=false

